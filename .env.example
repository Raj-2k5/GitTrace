# ============================================================
# GitTrace — Environment Variables
# Copy this file to `.env` and adjust values as needed.
# ============================================================

# Set to "true" to use the live GitHub API via Octokit.
# When "false" (default), the app returns mock data to avoid
# burning through GitHub's unauthenticated rate limit (60 req/hr).
VITE_USE_LIVE_API=false

# (Optional) GitHub Personal Access Token for higher rate limits.
# Uncomment and paste your token to get 5 000 req/hr instead of 60.
# VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Required for AI features) Google Gemini API Key.
# Get one at https://aistudio.google.com/app/apikey
# Without this key, the AI Progress Stories feature is disabled
# but the rest of the app works normally.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
