# ============================================================
# GitTrace — Environment Variables
# Copy this file to `.env` and adjust values as needed.
# ============================================================

# (Optional) GitHub Personal Access Token for higher rate limits.
# Without a token you get 60 req/hr; with one you get 5,000 req/hr.
# Get one at https://github.com/settings/tokens
# VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Required for AI features) Google Gemini API Key.
# Get one at https://aistudio.google.com/app/apikey
# Without this key, the "Generate AI Story" button will show
# an error, but the rest of the app works normally.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) GitHub OAuth App — for "Sign in with GitHub" button.
# Create an OAuth App at https://github.com/settings/developers
# Set the callback URL to your app's URL (e.g. http://localhost:5173)
# VITE_GITHUB_CLIENT_ID=your_oauth_client_id_here

# (Optional) OAuth token exchange proxy URL.
# A tiny serverless function that exchanges the OAuth code for a token.
# Required for the full OAuth flow. Without this, use VITE_GITHUB_TOKEN.
# VITE_OAUTH_PROXY_URL=https://your-proxy.vercel.app/api/auth
